{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": ".test-dist",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmit": false,
    "sourceMap": false,
    "declaration": false,
    "declarationMap": false
  },
  "include": [
    "electron/acp/**/*.ts",
    "electron/opencode-runtime.ts",
    "electron/opencode-runtime-acp.ts",
    "electron/workspace-service.ts",
    "src/features/chat/ChatView.tsx",
    "src/features/chat/MessageBlock.tsx",
    "src/features/navigation/AppTitleBar.tsx",
    "src/features/chat/FileCard.tsx",
    "src/features/shared/utils.ts",
    "src/features/workspace/labels.ts",
    "tests/electron/**/*.ts",
    "tests/frontend/**/*.ts",
    "tests/frontend/**/*.tsx"
  ]
}
