{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": ".test-dist",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmit": false,
    "sourceMap": false,
    "declaration": false,
    "declarationMap": false,
    "types": ["node", "react", "react-dom"]
  },
  "include": [
    "electron/agent-core/**/*.ts",
    "electron/media-permissions.ts",
    "electron/streaming-message-persister.ts",
    "electron/workspace-service.ts",
    "src/desktop-agent.d.ts",
    "src/markdown-it-task-lists.d.ts",
    "src/features/navigation/AppTitleBar.tsx",
    "src/features/navigation/PrimarySidebar.tsx",
    "src/lib/format.ts",
    "src/features/shared/utils.ts",
    "src/features/workspace/labels.ts",
    "tests/electron/**/*.ts",
    "tests/frontend/**/*.ts",
    "tests/frontend/**/*.tsx"
  ]
}
