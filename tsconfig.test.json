{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": ".test-dist",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmit": false,
    "sourceMap": false,
    "declaration": false,
    "declarationMap": false
  },
  "include": [
    "electron/workspace-service.ts",
    "src/features/navigation/AppTitleBar.tsx",
    "src/features/shared/utils.ts",
    "src/features/workspace/labels.ts",
    "tests/electron/**/*.ts",
    "tests/frontend/**/*.ts",
    "tests/frontend/**/*.tsx"
  ]
}
