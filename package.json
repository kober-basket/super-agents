{
  "name": "super-agents",
  "version": "0.1.0",
  "private": true,
  "description": "super-agents 桌面工作台外壳。",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite --strictPort --host 127.0.0.1 --port 5173",
    "dev:main": "tsup electron/main.ts electron/preload.ts --format cjs --out-dir dist-electron --watch --sourcemap --external electron",
    "dev:electron": "wait-on tcp:5173 file:dist-electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron dist-electron/main.js",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsup electron/main.ts electron/preload.ts --format cjs --out-dir dist-electron --minify --external electron",
    "test:electron": "tsc -p tsconfig.test.json && node -e \"const { spawnSync } = require('node:child_process'); const result = spawnSync(process.execPath, ['--test'], { cwd: '.test-dist', stdio: 'inherit' }); process.exit(result.status ?? 1);\"",
    "package": "npm run build && electron-builder --dir",
    "preview": "vite preview --host 127.0.0.1 --port 4173"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.18.2",
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@wecom/aibot-node-sdk": "^1.0.6",
    "clsx": "^2.1.1",
    "dingtalk-stream-sdk-nodejs": "^2.0.4",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.511.0",
    "mammoth": "^1.12.0",
    "marked": "^15.0.7",
    "mermaid": "^11.14.0",
    "mime-types": "^2.1.35",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-pdf": "^10.4.1",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.2"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.13.14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.5",
    "electron-builder": "^25.1.8",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.4",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.superagents.desktop.agent",
    "productName": "super-agents",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "vendor/opencode",
        "to": "vendor/opencode"
      }
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
