{
  "name": "super-agents",
  "version": "0.1.1",
  "private": true,
  "description": "super-agents 桌面工作台外壳。",
  "main": "dist-electron/main.js",
  "bin": {
    "super-agents": "scripts/super-agents.mjs",
    "super-agents-admin": "scripts/super-agents-admin.mjs",
    "super-agents-document-runtime": "scripts/super-agents-document-runtime.mjs"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite --strictPort --host 127.0.0.1 --port 5173",
    "dev:main": "tsup electron/main.ts electron/preload.ts --format cjs --out-dir dist-electron --watch --sourcemap --external electron",
    "dev:electron": "wait-on tcp:5173 file:dist-electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron --remote-debugging-port=9001 dist-electron/main.js",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsup electron/main.ts electron/preload.ts --format cjs --out-dir dist-electron --minify --external electron",
    "test:electron": "tsc -p tsconfig.test.json && node -e \"const { spawnSync } = require('node:child_process'); const result = spawnSync(process.execPath, ['--test'], { cwd: '.test-dist', stdio: 'inherit' }); process.exit(result.status ?? 1);\"",
    "package": "npm run build && electron-builder --dir",
    "package:runtime": "npm run runtime:check && npm run build && electron-builder",
    "package:runtime:win": "npm run runtime:check:win && npm run build && electron-builder --win --x64 && electron-builder --win --arm64",
    "package:runtime:win:x64": "npm run runtime:check:win:x64 && npm run build && electron-builder --win --x64",
    "package:runtime:win:arm64": "npm run runtime:check:win:arm64 && npm run build && electron-builder --win --arm64",
    "runtime:check": "node scripts/check-runtime.mjs",
    "runtime:check:win": "npm run runtime:check:win:x64 && npm run runtime:check:win:arm64",
    "runtime:check:win:x64": "cross-env SUPER_AGENTS_RUNTIME_PLATFORM=win32 SUPER_AGENTS_RUNTIME_ARCH=x64 node scripts/check-runtime.mjs",
    "runtime:check:win:arm64": "cross-env SUPER_AGENTS_RUNTIME_PLATFORM=win32 SUPER_AGENTS_RUNTIME_ARCH=arm64 node scripts/check-runtime.mjs",
    "runtime:install": "node scripts/install-runtime.mjs",
    "cli": "node scripts/super-agents.mjs",
    "admin": "node scripts/super-agents-admin.mjs",
    "preview": "vite preview --host 127.0.0.1 --port 4173"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.18.2",
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@wecom/aibot-node-sdk": "^1.0.6",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "dingtalk-stream-sdk-nodejs": "^2.0.4",
    "highlight.js": "^11.11.1",
    "imapflow": "^1.3.3",
    "lucide-react": "^0.511.0",
    "mailparser": "^3.9.8",
    "mammoth": "^1.12.0",
    "markdown-it": "^14.1.1",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.14.0",
    "mime-types": "^2.1.35",
    "node-pty": "^1.1.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-pdf": "^10.4.1",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.2"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-footnote": "^3.0.4",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^24.12.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^42.2.0",
    "electron-builder": "^25.1.8",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.4",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.superagents.desktop.agent",
    "productName": "super-agents",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "electron/builtin-skills/**",
      "node_modules/node-pty/**",
      "scripts/super-agents.mjs",
      "scripts/super-agents-admin.mjs",
      "scripts/super-agents-document-runtime.mjs",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**",
      "electron/builtin-skills/**"
    ],
    "npmRebuild": false,
    "win": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        "nsis"
      ],
      "extraResources": [
        {
          "from": "vendor/runtime/win32-${arch}",
          "to": "runtime/win32-${arch}",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "mac": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        "dmg"
      ],
      "extraResources": [
        {
          "from": "vendor/runtime/darwin-arm64",
          "to": "runtime/darwin-arm64",
          "filter": [
            "**/*"
          ]
        },
        {
          "from": "vendor/runtime/darwin-x64",
          "to": "runtime/darwin-x64",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
